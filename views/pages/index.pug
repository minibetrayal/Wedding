extends /layout
include /mixins/hero
include /mixins/gradientRule
include /mixins/cardLink
include /mixins/countdown

block title
  | #{coupleNames}

block content
  +hero(heroImages).mb-5

  +countdown

  .vstack.gap-3.mb-2
    +cardLink('/rsvp', 'calendar-check', 'RSVP')
      | Received an invitation? Let us know if you can join us!
    +cardLink('/faq', 'question-circle', 'FAQ')
      | Answers to common questions.
    +cardLink('/guestbook', 'journal-richtext', 'Guestbook')
      | Whether or not you can attend, you can read messages from other guests and leave a note, memory, or photo for us.
    if isRSVP
      +cardLink('/details', 'calendar-event', 'Wedding details')
        | Everything you need for the day — when and where, dress code, getting there, and more.
