extends /layout
include /mixins/inclusions

block title
  | Hero images — Admin

block append styles
  +style('photoGallery')
  +style('adminHero')

block append script
  +script('admin-hero-focus')

block content
  .container.py-4
    nav.mb-3(aria-label="Breadcrumb")
      ol.breadcrumb.mb-0
        li.breadcrumb-item
          a.link-secondary(href="/admin") Admin
        li.breadcrumb-item.active(aria-current="page") Hero images

    .d-flex.flex-column.flex-sm-row.align-items-stretch.align-items-sm-start.justify-content-between.gap-3.mb-4
      div
        h1.h3.mb-1 Hero carousel
        p.text-muted.small.mb-0
          | Upload images to be used on hero carousel elements and set their focus point.

    .card.border-0.shadow-sm.mb-4
      .card-body.p-4
        h2.h5.mb-1.d-inline-flex.align-items-center.gap-2
          i.bi.bi-image.text-primary(aria-hidden="true")
          | Upload hero images
        p.text-muted.small.mb-3
          | Choose one or more images (up to 40 per upload, 20 MB each).
        form(
          method="post",
          action="/admin/hero",
          enctype="multipart/form-data"
        )
          .mb-3
            label.form-label(for="admin-hero-photos-input") Image files
            input#admin-hero-photos-input.form-control(
              type="file",
              name="photos",
              accept="image/*",
              multiple,
              required
            )
          button.btn.btn-primary.d-inline-flex.align-items-center.gap-2(type="submit")
            i.bi.bi-cloud-upload(aria-hidden="true")
            | Upload

    if heroPhotoRows && heroPhotoRows.length
      section(aria-label="Hero images")
        h2.h6.text-uppercase.text-muted.mb-3 Current images
        .row.row-cols-1.row-cols-sm-2.row-cols-lg-3.g-4
          each row in heroPhotoRows
            - const photo = row.photo
            .col
              figure.card.gallery-card.no-animate.h-100.border-0.shadow-sm.overflow-hidden.mb-0
                .hero-focus-picker-wrap(
                  role="group",
                  aria-label=`Set carousel focus for ${photo.name || 'image'}`,
                  data-focus-url=`/admin/hero/${photo.id}/focus`
                )
                  img.hero-focus-img(
                    src=`/photos/${photo.id}`,
                    alt=photo.name ? `Hero image: ${photo.name}` : 'Hero image',
                    loading="lazy",
                    data-focus-y=row.focusY
                  )
                  .hero-focus-frame(aria-hidden="true")
                span.hero-focus-status.small.text-danger.px-1(role="status", aria-live="polite")
                p.hero-focus-hint.text-muted.small.px-1.pt-2.mb-2
                  | Click to set the vertical focus point for this image.
                figcaption.card-body.p-3.p-md-4.pt-0
                  if photo.name
                    p.small.text-muted.text-break.font-monospace.mb-2.mb-md-3(title=photo.name) #{photo.name}
                  form(method="post", action=`/admin/hero/${photo.id}/delete`)
                    button.btn.btn-sm.btn-outline-danger.d-inline-flex.align-items-center.justify-content-center.gap-1.w-100(
                      type="submit",
                      onclick="return confirm('Remove this image from the hero set? The file will be deleted.');"
                    )
                      i.bi.bi-trash(aria-hidden="true")
                      | Delete
    else
      .border.rounded-3.bg-body-secondary.bg-opacity-10.p-4.p-md-5.text-center
        i.bi.bi-images.display-4.text-muted.mb-3.d-block(aria-hidden="true")
        p.fw-semibold.mb-2 No hero images yet
        p.text-muted.small.mb-0 Upload images above to add them here.
