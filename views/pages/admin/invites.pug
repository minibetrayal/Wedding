extends /layout

block append styles
  style.
    .invite-list-item--has-details {
      background-color: rgba(var(--bs-info-rgb), 0.07);
    }
    a.invite-list-item--has-details.list-group-item-action:hover,
    a.invite-list-item--has-details.list-group-item-action:focus-visible {
      background-color: rgba(var(--bs-info-rgb), 0.12);
    }

block title
  | Invitations — Admin

block content

  .container.py-4
    nav.mb-3(aria-label="Breadcrumb")
      ol.breadcrumb.mb-0
        li.breadcrumb-item
          a.link-secondary(href="/admin") Admin
        li.breadcrumb-item.active(aria-current="page") Invitations

    .d-flex.flex-column.flex-sm-row.align-items-stretch.align-items-sm-center.justify-content-between.gap-3.mb-4
      div
        h1.h3.mb-1 Manage invitations
        p.text-muted.small.mb-0 Summary and per-invite status
      a.btn.btn-primary.btn-lg.d-inline-flex.align-items-center.justify-content-center.gap-2(href="/admin/invites/new")
        i.bi.bi-plus-lg(aria-hidden="true")
        | Create invitation

    //- Stats
    .row.row-cols-2.row-cols-md-3.row-cols-lg-6.g-3.mb-4
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.length}
            .small.text-muted Invites sent
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.reduce((acc, invite) => acc + invite.invitees.length, 0)}
            .small.text-muted Guests invited
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.filter(invite => !invite.seen).length}
            .small.text-muted Invites not seen
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.filter(invite => invite.seen).length}
            .small.text-muted Invites seen
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.filter(invite => invite.responded).length}
            .small.text-muted Responded
      .col
        .card.h-100.border.shadow-sm
          .card-body.text-center.py-3.px-2
            .fs-2.fw-semibold.text-body #{invites.reduce((acc, invite) => acc + invite.attending(), 0)}
            .small.text-muted Attending guests

    h2.h6.text-muted.text-uppercase.mb-2 All invitations
    if invites.length
      p.small.text-muted.mb-3
        span.d-block.mb-2 Status (left border)
        span.ms-1
          span.text-secondary.me-2.text-nowrap
            i.bi.bi-envelope.me-1(aria-hidden="true")
            | Not seen
          span.text-info.me-2.text-nowrap
            i.bi.bi-envelope-open.me-1(aria-hidden="true")
            | Seen
          span.text-warning.me-2.text-nowrap
            i.bi.bi-x-lg.me-1(aria-hidden="true")
            | Declined
          span.text-success.me-2.text-nowrap
            i.bi.bi-people-fill.me-1(aria-hidden="true")
            | Attending
          span.text-dark.me-2.text-nowrap
            i.bi.bi-chat-left-text.me-1(aria-hidden="true")
            | Guest note on invite
          span.text-dark.text-nowrap
            i.bi.bi-fork-knife.me-1(aria-hidden="true")
            | Special dietary info

      .list-group.shadow-sm
        - 
          const d = [
            ['Not seen', 'secondary', 'envelope'],
            ['Seen', 'info', 'envelope-open'],
            ['Declined', 'warning', 'x-lg'],
            ['Attending', 'success', 'people-fill'],
          ]
        each invite in invites
          - const index = invite.seen ? (invite.responded ? (invite.attending() > 0 ? 3 : 2) : 1) : 0;
          - const hasGuestNote = typeof invite.notes === 'string' && invite.notes.trim().length > 0
          - const hasAttendingDietary = invite.invitees.some((g) => g.attending === true && typeof g.dietaryRestrictions === 'string' && g.dietaryRestrictions.trim().length > 0)
          - const hasDetailsHighlight = hasGuestNote || hasAttendingDietary
          a.list-group-item.list-group-item-action.d-flex.align-items-center.gap-3.py-3.px-3(
            href=`/admin/invites/${invite.id}`,
            class=[
              `border-start border-4 border-${d[index][1]}`,
              hasDetailsHighlight && 'invite-list-item--has-details',
            ].filter(Boolean).join(' ')
          )
            .flex-shrink-0
              i.bi.fs-4(class=`bi-${d[index][2]} text-${d[index][1]}` aria-hidden="true")
            .flex-grow-1.min-w-0
              .fw-semibold.text-body.d-flex.flex-wrap.align-items-center.gap-2
                span #{invite.name}
                if hasGuestNote
                  span.badge.rounded-pill.text-bg-dark.border.border-dark(
                    title="This invite has guest notes"
                  )
                    i.bi.bi-chat-left-text(aria-hidden="true")
                    span.visually-hidden Guest note
                    span.d-none.d-sm-inline.ms-1 Note
                if hasAttendingDietary
                  span.badge.rounded-pill.text-bg-dark.border.border-dark(
                    title="At least one attending guest listed dietary requirements"
                  )
                    i.bi.bi-fork-knife(aria-hidden="true")
                    span.visually-hidden Dietary requirements
                    span.d-none.d-sm-inline.ms-1 Dietary
              .small.text-muted.mt-2.mt-sm-0 #{invite.attending()} attending · #{invite.invitees.length} invited
            .flex-shrink-0.small.text-muted.text-end
              span.visually-hidden Status:&nbsp;
              | #{d[index][0]}
            i.bi.bi-chevron-right.text-muted(aria-hidden="true")
    else
      .border.rounded-3.bg-body-secondary.bg-opacity-10.p-4.p-md-5.text-center
        i.bi.bi-inbox.display-4.text-muted.mb-3.d-block(aria-hidden="true")
        p.fw-semibold.mb-2 No invitations yet
        p.text-muted.small.mb-4
          | When you add invitations, they will show up here with status and guest counts.
        a.btn.btn-primary.d-inline-flex.align-items-center.gap-2(href="/admin/invites/new")
          i.bi.bi-plus-lg(aria-hidden="true")
          | Create invitation
