extends /layout
include /mixins/cardLink
include /mixins/gemline
include /mixins/notificationBadge

block title
  | Admin

block content
  .row.justify-content-center
    .col-12.col-md-10.col-lg-7.col-xl-6
      h1.h3.mb-1 Admin
      p.text-muted.small.mb-4
        | Manage wedding site content.

      //- Stack of tappable cards (Bootstrap utilities only; mobile-first)
      .vstack.gap-3
        +cardLink('/admin/invites', 'envelope-open', 'Manage invitations')
          | View and edit guest invites and related settings.
        +cardLink('/admin/projector', 'projector', 'Reception projector')
          | Choose home, a custom message, or guestbook rotation and timing for the big screen.
        div
          +cardLink('/guestbook/moderation', 'shield-exclamation', 'Guestbook moderation')
            | Review hidden posts the author edited after removal — confirm or show publicly.
          +notificationBadge(data-am-count=moderationEntries)

      +gemline(5, 5)

      .vstack.gap-3.mb-2
        +cardLink('/admin/names', 'people', 'Names & contact')
          | Names and contact information.
        +cardLink('/admin/schedule', 'calendar-event', 'Schedule')
          | Event times for the day.
        +cardLink('/admin/locations', 'geo-alt', 'Locations')
          | Ceremony, reception, ferry, and other place names and addresses.
        +cardLink('/admin/times', 'clock', 'Travel Times')
          | Times to travel to and from various locations.
        +cardLink('/admin/menu', 'cup-hot', 'Menu')
          | Wedding meal courses and dishes (dietary tags).
        +cardLink('/admin/hero', 'image', 'Hero carousel')
          | Upload, edit and remove images used on the home page carousel.
        +cardLink('/admin/ferry', 'water', 'Ferry timetable')
          | Edit suggested ferry services shown on the Details page.
        +cardLink('/admin/faq', 'question-circle', 'FAQ')
          | Edit the FAQ shown on the FAQ page.

      +gemline(5, 5)

      .vstack.gap-3.mb-2
        +cardLink('/admin/settings', 'gear', 'Site settings')
          | Edit site settings.

      //- Log out — full-width control, easy to hit with a thumb
      .mt-4.pt-3.border-top
        a.btn.btn-lg.btn-outline-danger.w-100.d-flex.align-items-center.justify-content-center.gap-2.rounded-3(
          href="/admin/logout"
        )
          i.bi.bi-box-arrow-right(aria-hidden="true")
          | Log out
