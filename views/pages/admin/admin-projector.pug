extends /layout
include /mixins/inclusions
include /mixins/textareaCounter
include /mixins/validationForm

block append script
  +adminScript('admin-projector')

block title
  | Projector — Admin

block content
  -
    const hasMessageText = typeof projector.message === 'string' && projector.message.trim().length > 0
    const saveDisabledInitial = !hasMessageText && projector.mode === 'message'
  #projector-admin-settings(
    data-mode-url="/admin/projector/mode",
    data-dwell-url="/admin/projector/dwell",
    data-paused-url="/admin/projector/pause",
    data-darkmode-url="/admin/projector/darkmode",
    data-initial-mode=projector.mode,
    data-initial-dwell-sec=dwellSecondsSnapped,
    data-initial-paused=projector.paused ? 'true' : 'false',
    data-initial-darkmode=projector.darkMode ? 'dark' : 'light'
  )
    nav.mb-3(aria-label="Breadcrumb")
      ol.breadcrumb.mb-0
        li.breadcrumb-item
          a.link-secondary(href="/admin") Admin
        li.breadcrumb-item.active(aria-current="page") Projector

    .d-flex.flex-column.flex-sm-row.align-items-stretch.align-items-sm-start.justify-content-between.gap-3.mb-4
      div
        h1.h3.mb-1 Reception projector
        p.text-muted.small.mb-0
          | Use the options below to choose how the projector displays content.
      a.btn.btn-outline-primary.btn-lg.d-inline-flex.align-items-center.justify-content-center.gap-2.align-self-stretch.align-self-sm-center(
        href="/projector",
        target="_blank",
        rel="noopener noreferrer"
      )
        i.bi.bi-box-arrow-up-right(aria-hidden="true")
        | Open projector

    .card.border.shadow-sm.mb-3
      .card-body
        legend.form-label.fw-semibold.mb-3 Display mode
        .vstack.gap-2
          .form-check
            input.form-check-input#mode-home(
              type="radio",
              name="projector-mode",
              value="home",
              checked=projector.mode === 'home'
            )
            label.form-check-label(for="mode-home") Home — rotating photos of #{coupleNames}
          .form-check
            input.form-check-input#mode-message(
              type="radio",
              name="projector-mode",
              value="message",
              checked=projector.mode === 'message',
              disabled=!hasMessageText,
              aria-describedby=hasMessageText ? undefined : 'projector-message-save-hint'
            )
            label.form-check-label(for="mode-message") Message — full-screen text set below (e.g. “Please take your seats”)
            p#projector-message-save-hint.small.text-muted.mb-0.mt-1.ms-4.ps-1(class=hasMessageText ? 'd-none' : '')
              | Set a message below before enabling Message mode.
          .form-check
            input.form-check-input#mode-guestbook(
              type="radio",
              name="projector-mode",
              value="guestbook",
              checked=projector.mode === 'guestbook'
            )
            label.form-check-label(for="mode-guestbook") Guestbook — rotate through public posts
            p#projector-guestbook-count-hint.small.text-muted.mb-0.mt-1.ms-4.ps-1(
              role="status",
              aria-live="polite",
              aria-atomic="true"
            )
              | #{guestbookEntryCount} eligible post#{guestbookEntryCount === 1 ? '' : 's'} (visible, not moderated).
        p#projector-mode-status.small.text-muted.mb-0.mt-2(role="status", aria-live="polite")

    .card.border.shadow-sm.mb-3(data-bs-theme=projector.darkMode ? 'dark' : 'light')
      .card-body
        legend.form-label.fw-semibold.mb-3 Dark mode
        .vstack.gap-2
          .btn-group(role="group")
            input.btn-check#darkmode-light(
              type="radio",
              name="projector-darkmode",
              value="light",
              checked=projector.darkMode === false
            )
            label.btn.btn-outline-secondary(for="darkmode-light") Light mode
            input.btn-check#darkmode-dark(
              type="radio",
              name="projector-darkmode",
              value="dark",
              checked=projector.darkMode === true
            )
            label.btn.btn-outline-dark(for="darkmode-dark") Dark mode
        p#darkmode-status.small.text-muted.mb-0.mt-2(role="status", aria-live="polite")

    .card.border.shadow-sm.mb-3
      .card-body
        label.form-label.fw-semibold(for="projector-dwell-slider") Seconds per guestbook slide
        .d-flex.align-items-center.gap-3.flex-wrap
          input#projector-dwell-slider.form-range.flex-grow-1(
            type="range",
            min=dwellMinSec,
            max=dwellMaxSec,
            step=dwellStepSec,
            value=dwellSecondsSnapped,
            aria-valuemin=dwellMinSec,
            aria-valuemax=dwellMaxSec,
            aria-valuenow=dwellSecondsSnapped,
            aria-describedby="projector-dwell-hint"
          )
          span#projector-dwell-label.fw-semibold.tabular-nums #{dwellSecondsSnapped}s
        p#projector-dwell-hint.form-text.mb-1
          | #{dwellMinSec}–#{dwellMaxSec} seconds.
        p#projector-dwell-status.small.text-muted.mb-0(role="status", aria-live="polite")

    .card.border.shadow-sm.mb-3
      .card-body
        legend.form-label.fw-semibold.mb-2 Guestbook rotation
        p.small.text-muted.mb-3
          | While the projector is in Guestbook mode, entries advance automatically. Pause to hold the current entry on screen (e.g. during speeches). Play resumes rotation after the dwell time.
        button#projector-pause-toggle.btn.btn-outline-secondary.d-inline-flex.align-items-center.gap-2(
          type="button",
          aria-pressed=projector.paused ? 'true' : 'false'
        )
          if projector.paused
            i#projector-pause-icon.bi.bi-play-fill(aria-hidden="true")
            span#projector-pause-label Play rotation
          else
            i#projector-pause-icon.bi.bi-pause-fill(aria-hidden="true")
            span#projector-pause-label Pause rotation
        p#projector-pause-status.small.text-muted.mb-0.mt-2(role="status", aria-live="polite")

    +validationForm.suppress-enter-submit(method="post", action="/admin/projector/message")
      .card.border.shadow-sm.mb-4
        .card-body
          label.form-label.fw-semibold(for="projector-message") Message text
          +textareaCounter#projector-message.form-control(
            name="message",
            rows="4",
            maxlength=projectorMessageMax,
            placeholder="Shown when “Message” mode is selected"
          )
            = projector.message
          .form-text.mb-3
            | Save stores the text (empty is allowed unless Message mode is selected in the UI). Save and Display switches to message mode and requires non-empty text. The mode buttons apply immediately; Message mode also saves the current field contents to the projector.
          .d-flex.flex-column.flex-sm-row.align-items-stretch.gap-2
            button#projector-message-btn-save.btn.btn-outline-secondary.d-inline-flex.align-items-center.justify-content-center.gap-2(
              type="submit",
              name="messageAction",
              value="save",
              disabled=saveDisabledInitial
            )
              i.bi.bi-floppy2(aria-hidden="true")
              | Save
            button#projector-message-btn-save-display.btn.btn-outline-primary.d-inline-flex.align-items-center.justify-content-center.gap-2(
              type="submit",
              name="messageAction",
              value="saveAndShow",
              disabled=!hasMessageText
            )
              i.bi.bi-projector(aria-hidden="true")
              | Save and Display

