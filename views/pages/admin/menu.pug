extends /layout
include /mixins/inclusions
include /mixins/validationForm

block append script
  +script('admin-menu')

block title
  | Menu — Admin

block content
  nav.mb-3(aria-label="Breadcrumb")
    ol.breadcrumb.mb-0
      li.breadcrumb-item
        a.link-secondary(href="/admin") Admin
      li.breadcrumb-item.active(aria-current="page") Menu

  .mb-4
    h1.h3.mb-1 Menu
    p.text-muted.small.mb-0
      | Courses and dishes for the wedding meal. Tick dietary tags for each line. Empty sections are ignored when you save.

  +validationForm.suppress-enter-submit#menu-form(method="post", action="/admin/menu")
    #menu-courses.vstack.gap-4
      each course, ci in courses
        .menu-course.border.rounded-3.p-3.bg-body-secondary.bg-opacity-25(data-course-index=ci)
          .d-flex.justify-content-between.align-items-start.flex-wrap.gap-2.mb-3
            h2.h6.mb-0 Course section
            button.btn.btn-outline-danger.btn-sm.remove-menu-course(
              type="button",
              aria-label="Remove this course section"
            )
              i.bi.bi-trash.me-1(aria-hidden="true")
              | Remove Course
          .mb-3
            label.form-label.small.mb-1(for=`menu-course-name-${ci}`) Course name
            input.menu-course-name.form-control.form-control-sm(
              id=`menu-course-name-${ci}`,
              type="text",
              name=`courses[${ci}][name]`,
              value=course.name,
              placeholder="e.g. Entrées, Mains",
              autocomplete="off",
              required
            )
            .invalid-feedback.small Please enter a course name.
          h3.h6.mb-2 Dishes
          .menu-items.vstack.gap-3
            each item, ii in course.items
              .menu-item.border.rounded-3.p-3.bg-body.bg-opacity-50
                .d-flex.justify-content-end.mb-2
                  button.btn.btn-outline-danger.btn-sm.remove-menu-item(
                    type="button",
                    aria-label="Remove this dish"
                  )
                    i.bi.bi-trash.me-1(aria-hidden="true")
                    | Remove Dish
                .mb-3
                  label.form-label.small.mb-1 Dish name
                  input.menu-item-name.form-control.form-control-sm(
                    type="text",
                    name=`courses[${ci}][items][${ii}][name]`,
                    value=item.name,
                    placeholder="e.g. Herb-crusted lamb, fondant potato",
                    autocomplete="off",
                    required
                  )
                  .invalid-feedback.small Please enter a dish name.
                div
                  label.form-label.small.mb-2 Dietary tags
                  .menu-item-tags 
                    .row.row-cols-1.row-cols-sm-2.g-2
                      .col.d-flex.flex-column.gap-2
                        each tag in menuTags.filter(tag => !tag.endsWith('Option')).sort()
                          label.form-check.small.mb-0
                            - var checked = (item.tags || []).indexOf(tag) !== -1
                            input.form-check-input(
                              type="checkbox",
                              name=`courses[${ci}][items][${ii}][tags][]`,
                              value=tag,
                              checked=checked
                            )
                            = ' ' + tag
                      .col.d-flex.flex-column.gap-2
                        each tag in menuTags.filter(tag => tag.endsWith('Option')).sort()
                          label.form-check.small.mb-0
                            - var checked = (item.tags || []).indexOf(tag) !== -1
                            input.form-check-input(
                              type="checkbox",
                              name=`courses[${ci}][items][${ii}][tags][]`,
                              value=tag,
                              checked=checked
                            )
                            = ' ' + tag

          .mt-2
            button.btn.btn-outline-secondary.btn-sm.add-menu-item(type="button")
              i.bi.bi-plus-lg.me-1(aria-hidden="true")
              | Add Dish

    .d-flex.flex-wrap.align-items-center.gap-2.mb-4
      button.btn.btn-outline-secondary.btn-sm#add-menu-course(type="button")
        i.bi.bi-plus-lg.me-1(aria-hidden="true")
        | Add Course

    template#menu-course-template
      .menu-course.border.rounded-3.p-3.bg-body-secondary.bg-opacity-25
        .d-flex.justify-content-between.align-items-start.flex-wrap.gap-2.mb-3
          h2.h6.mb-0 Course section
          button.btn.btn-outline-danger.btn-sm.remove-menu-course(
            type="button",
            aria-label="Remove this course section"
          )
            i.bi.bi-trash.me-1(aria-hidden="true")
            | Remove Course
        .mb-3
          label.form-label.small.mb-1(for="menu-course-name-__ci__") Course name
          input.menu-course-name.form-control.form-control-sm(
            id="menu-course-name-__ci__",
            type="text",
            name="courses[__ci__][name]",
            placeholder="e.g. Entrées, Mains",
            autocomplete="off",
            required
          )
          .invalid-feedback.small Please enter a course name.
        h3.h6.mb-2 Dishes
        .menu-items.vstack.gap-3
          .menu-item.border.rounded-3.p-3.bg-body.bg-opacity-50
            .d-flex.justify-content-end.mb-2
              button.btn.btn-outline-danger.btn-sm.remove-menu-item(
                type="button",
                aria-label="Remove this dish"
              )
                i.bi.bi-trash.me-1(aria-hidden="true")
                | Remove Dish
            .mb-3
              label.form-label.small.mb-1 Dish name
              input.menu-item-name.form-control.form-control-sm(
                type="text",
                name="courses[__ci__][items][__ii__][name]",
                placeholder="e.g. Herb-crusted lamb, fondant potato",
                autocomplete="off",
                required
              )
              .invalid-feedback.small Please enter a dish name.
            div
              label.form-label.small.mb-2 Dietary tags
              .menu-item-tags 
                .row.row-cols-1.row-cols-sm-2.g-2
                  .col.d-flex.flex-column.gap-2
                    each tag in menuTags.filter(tag => !tag.endsWith('Option')).sort()
                      label.form-check.small.mb-0
                        input.form-check-input(
                          type="checkbox",
                          name=`courses[__ci__][items][__ii__][tags][]`,
                          value=tag,
                          checked=checked
                        )
                        = ' ' + tag
                  .col.d-flex.flex-column.gap-2
                    each tag in menuTags.filter(tag => tag.endsWith('Option')).sort()
                      label.form-check.small.mb-0
                        input.form-check-input(
                          type="checkbox",
                          name=`courses[__ci__][items][__ii__][tags][]`,
                          value=tag,
                          checked=checked
                        )
                        = ' ' + tag
        .mt-2
          button.btn.btn-outline-secondary.btn-sm.add-menu-item(type="button")
            i.bi.bi-plus-lg.me-1(aria-hidden="true")
            | Add Dish

    template#menu-item-template
      .menu-item.border.rounded-3.p-3.bg-body.bg-opacity-50
        .d-flex.justify-content-end.mb-2
          button.btn.btn-outline-danger.btn-sm.remove-menu-item(
            type="button",
            aria-label="Remove this dish"
          )
            i.bi.bi-trash.me-1(aria-hidden="true")
            | Remove Dish
        .mb-3
          label.form-label.small.mb-1 Dish name
          input.menu-item-name.form-control.form-control-sm(
            type="text",
            name="courses[__ci__][items][__ii__][name]",
            placeholder="e.g. Herb-crusted lamb, fondant potato",
            autocomplete="off",
            required
          )
          .invalid-feedback.small Please enter a dish name.
        div
          label.form-label.small.mb-2 Dietary tags
          .menu-item-tags 
            .row.row-cols-1.row-cols-sm-2.g-2
              .col.d-flex.flex-column.gap-2
                each tag in menuTags.filter(tag => !tag.endsWith('Option')).sort()
                  label.form-check.small.mb-0
                    input.form-check-input(
                      type="checkbox",
                      name=`courses[__ci__][items][__ii__][tags][]`,
                      value=tag,
                      checked=checked
                    )
                    = ' ' + tag
              .col.d-flex.flex-column.gap-2
                each tag in menuTags.filter(tag => tag.endsWith('Option')).sort()
                  label.form-check.small.mb-0
                    input.form-check-input(
                      type="checkbox",
                      name=`courses[__ci__][items][__ii__][tags][]`,
                      value=tag,
                      checked=checked
                    )
                    = ' ' + tag

    .d-flex.flex-wrap.gap-2
      button.btn.btn-primary(type="submit")
        i.bi.bi-check2.me-1(aria-hidden="true")
        | Save menu
      a.btn.btn-outline-secondary(href="/admin") Cancel
