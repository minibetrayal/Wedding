doctype html
include /mixins/inclusions
include /mixins/hero

html(lang="en-AU")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")

    title #{coupleNamesShort} — Projector

    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap")
    link(rel="stylesheet", href="/icons/bootstrap-icons.min.css")

    +style('main')
    +heroStyle 
    +style('projector')

    link(rel="icon" type="image/svg+xml" href="/images/anm.svg")

  body.projector-layout.d-flex.flex-column.min-vh-100.min-dvh-100.bg-body.text-body
    main.flex-fill.d-flex.flex-column.min-vh-100.min-dvh-100
      script.projector-state(type="application/json")!= JSON.stringify(projector).replace(/</g, '\\u003c')

      .projector-root(role="region", aria-label="Wedding projector display")
        section.projector-section.d-none(data-am-mode="home")
          .projector-panel
            +hero(heroImages)

        section.projector-section.d-none(data-am-mode="message")
          .projector-panel
            .projector-message-wrap
              p.projector-message


    +script('bootstrap.bundle.min')
    +script('projector')
