//-
  Guest RSVP form. Locals:
  - invite: Invite (id, name, phone?, email?, notes?, invitees[] with id, name, attending?, dietaryRestrictions?)
  Recipient and guest names are read-only; guests cannot add/remove people or change the invitation title.
  POST target: /rsvp/:inviteId.
  Field names align with admin invite-edit for phone, email, notes, invitees[i][id|name|attending|dietaryRestrictions].
  Attending is required per guest (true or false only). Contact fields are always visible; per-guest dietary is collapsible.

extends /layout
include /mixins/inclusions
include /mixins/hero

block styles
  +heroStyle

block title
  | #{coupleNamesShort} — RSVP

block top

block content
  -
    const inv = typeof invite !== 'undefined' && invite ? invite : {}
    const guestRows = inv.invitees && inv.invitees.length ? inv.invitees : []

  .container.py-4.py-md-5
    +hero(inv.name)

    h3.p-1.my-5.text-center.vibes-script.mb-0 We cordially invite you to celebrate our wedding

    .accordion.mt-5#rsvp-accordion
      .accordion-item
        h2.accordion-header
          button.accordion-button(
            type="button",
            class=inv.seen ? '' : 'collapsed',
            data-bs-toggle="collapse",
            data-bs-target="#rsvp-accordion-panel",
            aria-expanded=inv.seen ? 'true' : 'false',
            aria-controls="rsvp-accordion-panel"
          )
            strong.ms-auto.h1 RSVP

        #rsvp-accordion-panel.accordion-collapse.collapse(class=inv.seen ? 'show' : '', data-bs-parent="#rsvp-accordion")
          .accordion-body
            form#rsvp-edit-form(
              method="post",
              action='/rsvp/' + inv.id,
              novalidate
            )
              .card.border.shadow-sm.mb-4
                .card-body
                  h2.h6.text-uppercase.text-muted.mb-2 Guests
                  p.small.text-muted.mb-3
                    | For each person listed, let us know if they can attend. Add dietary details only if needed.

                  .invitee-rows.d-flex.flex-column.gap-3
                    each invitee, index in guestRows
                      - const dietaryFilled = typeof invitee.dietaryRestrictions === 'string' && invitee.dietaryRestrictions.trim().length > 0
                      .invitee-row.card.card-body.py-3.px-3.border(data-invitee-row)
                        input(type="hidden", name=`invitees[${index}][id]`, value=invitee.id || '')
                        input(type="hidden", name=`invitees[${index}][name]`, value=invitee.name || '')
                        .row.align-items-lg-center.g-3
                          .col-12.col-lg-4
                            p.small.text-muted.mb-1 Guest
                            h3.mb-0.vibes-script #{invitee.name || '—'}
                          .col-12.col-lg-8
                            fieldset.p-0.m-0.border-0
                              legend.form-label.small.mb-2
                                | Will you attend?
                                span.text-danger(aria-hidden="true") &nbsp;*
                              .btn-group.invitee-attending-group.w-100.w-sm-auto.rounded-pill.overflow-hidden(
                                role="group",
                                aria-label=`Attendance for ${invitee.name || 'guest ' + (index + 1)}`
                              )
                                input.btn-check.invitee-attending-radio(
                                  type="radio",
                                  name=`invitees[${index}][attending]`,
                                  id=`rsvp-invitee-${index}-attend-no`,
                                  value="false",
                                  checked=invitee.attending === false,
                                  autocomplete="off"
                                )
                                label.btn.btn-outline-danger(for=`rsvp-invitee-${index}-attend-no`) Not Attending
                                input.btn-check.invitee-attending-radio(
                                  type="radio",
                                  name=`invitees[${index}][attending]`,
                                  id=`rsvp-invitee-${index}-attend-yes`,
                                  value="true",
                                  checked=invitee.attending === true,
                                  autocomplete="off"
                                )
                                label.btn.btn-outline-primary(for=`rsvp-invitee-${index}-attend-yes`) Attending
                              .attending-invalid-feedback.small.text-danger.mt-2.d-none
                                | Please choose whether this guest is attending or not.

                        .mt-3.pt-3.border-top
                          - const dietToggleId = `rsvp-dietary-toggle-${index}`
                          - const dietCollapseId = `rsvp-dietary-${index}`
                          button.btn.btn-sm.btn-link.text-decoration-none.d-inline-flex.align-items-center.gap-1.px-0(
                            id=dietToggleId,
                            type="button",
                            class=dietaryFilled ? '' : 'collapsed',
                            data-bs-toggle="collapse",
                            data-bs-target=`#${dietCollapseId}`,
                            aria-expanded=dietaryFilled ? 'true' : 'false',
                            aria-controls=dietCollapseId
                          )
                            span Dietary requirements
                            span.text-muted.fw-normal (optional)
                            i.bi.bi-chevron-down.small.collapse-chevron(aria-hidden="true")
                          .collapse(id=dietCollapseId class=dietaryFilled ? 'show' : '')
                            label.form-label.small.mt-2(for=`rsvp-invitee-${index}-dietary`) Allergies or requirements for this guest
                            textarea.form-control(
                              id=`rsvp-invitee-${index}-dietary`,
                              name=`invitees[${index}][dietaryRestrictions]`,
                              rows="2",
                              placeholder="Leave blank if none."
                            ) #{invitee.dietaryRestrictions || ''}

              .card.border.shadow-sm.mb-4
                .card-body
                  h2.h6.text-uppercase.text-muted.mb-3 Information

                  .row.g-3
                    .col-md-6
                      label.form-label(for="rsvp-phone") Phone
                        span.text-danger(aria-hidden="true") &nbsp;*
                      input#rsvp-phone.form-control(
                        type="tel",
                        name="phone",
                        autocomplete="tel",
                        placeholder="Required",
                        value=inv.phone || '',
                        required
                      )
                      .invalid-feedback Please enter your phone number.
                      .form-text.small 
                        | Please enter a mobile phone number we can use to reach you on the day. We will not use 
                        | this for any other purpose. 
                        br
                        | If your have a non-Australian number, please include the country code.
                    .col-md-6
                      label.form-label(for="rsvp-email") Email
                      input#rsvp-email.form-control(
                        type="email",
                        name="email",
                        autocomplete="email",
                        placeholder="Optional",
                        value=inv.email || ''
                      )
                      .form-text.small Optional — for confirmations or updates.
                  .mb-0.mt-3
                    label.form-label(for="rsvp-notes") Other information or questions
                    textarea#rsvp-notes.form-control(
                      name="notes",
                      rows="3",
                      placeholder="Optional"
                    ) #{inv.notes || ''}
                    .form-text.small 
                      | Please let us know anything else you think we should know about to help us organise the day.
                      br
                      | If you want to leave a thoughtful message for us, write it in the 
                      a.fw-semibold.link-primary(href="/guestbook") Guestbook
                      |  rather than here.

              .d-flex.flex-wrap.align-items-center.gap-2
                button.btn.btn-outline-primary.d-inline-flex.align-items-center.gap-2(type="submit")
                  i.bi.bi-check-lg(aria-hidden="true")
                  if (inv.responded)
                    | Update RSVP
                  else
                    | Submit RSVP

                p.small.text-muted.mb-0
                  | Once submitted, you can edit your RSVP by re-scanning your QR code or entering your invitation code manually 
                  | on the 
                  a.fw-semibold.link-primary(href="/rsvp") RSVP page
                  | .


    .py-4

    .mt-3.p-3.rounded-4.border.bg-white.shadow-sm
        .d-flex.align-items-start.gap-2
            i.bi.bi-question-circle.text-warning
            p.mb-0.small
                | Not you? Try scanning your QR code again or enter your invitation code manually 
                a.fw-semibold.link-primary(href="/rsvp") here
                | .

    .mt-3.p-3.rounded-4.border.bg-white.shadow-sm
        .d-flex.align-items-start.gap-2
            i.bi.bi-info-circle.text-primary
            p.mb-0.small
                | Want the full plan? See 
                a.fw-semibold.link-primary(href="/details") Details
                |  for transport info, timings, and dress code.

    .mt-3.p-3.rounded-4.border.bg-white.shadow-sm
        .d-flex.align-items-start.gap-2
            i.bi.bi-pencil.text-secondary
            p.mb-0.small
                | Want to leave a thoughtful message for us? Write it in the 
                a.fw-semibold.link-primary(href="/guestbook") Guestbook
                | !


block script
  +script('formValidate')
  script.
    document.addEventListener('DOMContentLoaded', function () {
      var form = document.getElementById('rsvp-edit-form');
      if (!form) return;
      form.customValidationFunctions = form.customValidationFunctions || [];
      form.customValidationFunctions.push(function () {
        var ok = true;
        form.querySelectorAll('[data-invitee-row]').forEach(function (row) {
          var picked = row.querySelector('input.invitee-attending-radio:checked');
          var fb = row.querySelector('.attending-invalid-feedback');
          if (!picked) {
            ok = false;
            if (fb) fb.classList.remove('d-none');
          } else if (fb) {
            fb.classList.add('d-none');
          }
        });
        return ok;
      });
      form.querySelectorAll('input.invitee-attending-radio').forEach(function (radio) {
        radio.addEventListener('change', function () {
          var row = radio.closest('[data-invitee-row]');
          if (!row) return;
          var fb = row.querySelector('.attending-invalid-feedback');
          if (fb) fb.classList.add('d-none');
        });
      });

      /* Leave-page warning: compare to initial snapshot (browsers usually show a generic message). */
      function rsvpFormSignature(f) {
        var fd = new FormData(f);
        var parts = [];
        fd.forEach(function (val, key) {
          parts.push(key + '\u0000' + String(val));
        });
        parts.sort();
        return parts.join('\u0001');
      }
      var initialSignature = rsvpFormSignature(form);
      var allowUnloadWithoutPrompt = false;
      form.addEventListener('submit', function (e) {
        if (!e.defaultPrevented) {
          allowUnloadWithoutPrompt = true;
        }
      });
      window.addEventListener('beforeunload', function (e) {
        if (allowUnloadWithoutPrompt) return;
        if (rsvpFormSignature(form) === initialSignature) return;
        e.preventDefault();
        e.returnValue = '';
      });
    });
