# Copy this file to .env and adjust as needed.
# .env is gitignored; this file is committed so you can set up new devices easily.

# Server port (default 3000 if not set)
PORT=3000

# development | production – affects error page detail level
NODE_ENV=development

# Couple Names
COUPLE_NAMES=Jane & John
COUPLE_NAMES_SHORT=J&J

# Contact
CONTACT_NAME=MC Name
CONTACT_PHONE=+1 234 567 890

# Event Details
EVENT_DATE=2028-01-15
EVENT_TIMEZONE=Australia/Sydney
EVENT_TIMEZONE_LABEL=Australian Eastern Daylight Time (AEDT)

# Schedule (keys must match SCHEDULE_* env var names below)
ARRIVAL_TIME_KEY=SCHEDULE_ARRIVAL_AND_WELCOME
CEREMONY_TIME_KEY=SCHEDULE_CEREMONY_BEGINS
RECEPTION_TIME_KEY=SCHEDULE_RECEPTION
SCHEDULE_ARRIVAL_AND_WELCOME=11:00:00+11:00
SCHEDULE_CEREMONY_BEGINS=14:00:00+11:00
SCHEDULE_PHOTOS=14:30:00+11:00
SCHEDULE_DRINKS_AND_MINGLING=15:00:00+11:00
SCHEDULE_RETURN_TO_MAINLAND=16:00:00+11:00
SCHEDULE_RECEPTION=17:00:00+11:00
SCHEDULE_DINNER=18:00:00+11:00
SCHEDULE_PARTY=19:00:00+11:00
SCHEDULE_END_OF_THE_DAY=21:00:00+11:00

# Locations
LOCATION_ISLAND_SHORT=Example Island
LOCATION_ISLAND_FERRY_SHORT=Example Island Ferry Terminal
LOCATION_CEREMONY=123 Sample Street, Example Island, State 4000
LOCATION_CEREMONY_SHORT=123 Sample Street
LOCATION_RECEPTION=Example Hotel, Main Town, State 4001
LOCATION_RECEPTION_SHORT=Example Hotel
LOCATION_MAINLAND_SHORT=Mainland Marina
LOCATION_MAINLAND_MARINA=Mainland Marina, Harbour Road, Main Town, State 4001
LOCATION_TRAIN_STATION=Main Town Station, Station Street, Main Town, State 4001
LOCATION_TRAIN_STATION_SHORT=Main Town Station
LOCATION_CAR_PARK=Example Road Car Park, Main Town, State 4001
LOCATION_CAR_PARK_SHORT=Example Road Car Park

# Travel Times (minutes)
TIME_TRAIN_TO_MAINLAND=45
TIME_CAR_PARK_TO_ISLAND=5
TIME_ISLAND_TO_CEREMONY=10-15
TIME_MAINLAND_TO_RECEPTION=25
TIME_MAINLAND_TO_ISLAND=25-35

# Ferry Services
FERRY_SERVICE_TO_ISLAND_1_PLATFORM=Platform 1
FERRY_SERVICE_TO_ISLAND_1_TIME=11:00:00+11:00
FERRY_SERVICE_TO_ISLAND_1_VIA=Stopover Island
FERRY_SERVICE_TO_ISLAND_1_ARRIVING=11:20:00+11:00

FERRY_SERVICE_TO_ISLAND_2_PLATFORM=Platform 1
FERRY_SERVICE_TO_ISLAND_2_TIME=10:30:00+11:00
FERRY_SERVICE_TO_ISLAND_2_VIA=Stopover Island
FERRY_SERVICE_TO_ISLAND_2_ARRIVING=10:50:00+11:00

FERRY_SERVICE_TO_ISLAND_3_PLATFORM=Platform 2
FERRY_SERVICE_TO_ISLAND_3_TIME=10:00:00+11:00
FERRY_SERVICE_TO_ISLAND_3_VIA=Other Island
FERRY_SERVICE_TO_ISLAND_3_ARRIVING=10:45:00+11:00

LINK_FERRY_TIMETABLE=https://example.com/ferry-timetable

COST_FERRY=$X.XX AUD

# Menu
MENU_COURSE_1=Appetizers
MENU_APPETIZERS_1=Example canapés
MENU_APPETIZERS_2=Seasonal bites
MENU_APPETIZERS_3=Cheese board
MENU_COURSE_2=Main Course
MENU_MAIN_COURSE_1=Example fish dish
MENU_MAIN_COURSE_2=Roast of the day
MENU_MAIN_COURSE_3=Vegetarian option
MENU_COURSE_3=Desserts
MENU_DESSERTS_1=Seasonal fruit
MENU_DESSERTS_2=Chocolate dessert
MENU_DESSERTS_3=Cheese and biscuits
