{
  "name": "wedding2",
  "version": "1.0.0",
  "description": "Express + TypeScript website with Pug",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js && npm run build:icons && tsc",
    "build:js": "node scripts/copy-bootstrap-js.cjs",
    "build:icons": "node scripts/copy-bootstrap-icons.cjs",
    "build:css": "sass --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --load-path=node_modules --quiet-deps styles:public/styles",
    "build:css:watch": "sass --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --load-path=node_modules --quiet-deps --watch styles:public/styles",
    "start": "node dist/index.js",
    "generate:dummy-data": "node scripts/generate-dummy-invites-guestbook.cjs",
    "dev": "npm run build && concurrently \"npm run build:css:watch\" \"ts-node-dev --respawn --transpile-only src/index.ts\"",
    "heroku-postbuild": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "better-sqlite3": "^12.8.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "knex": "^3.2.6",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@types/connect-flash": "^0.0.40",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "concurrently": "^9.2.1",
    "sass": "^1.98.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
