{
  "name": "wedding2",
  "version": "1.0.0",
  "description": "Express + TypeScript website with Pug",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js && npm run build:icons && tsc",
    "build:js": "node scripts/copy-bootstrap-js.cjs",
    "build:icons": "node scripts/copy-bootstrap-icons.cjs",
    "build:css": "sass --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --load-path=node_modules --quiet-deps styles:public/styles",
    "build:css:watch": "sass --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --load-path=node_modules --quiet-deps --watch styles:public/styles",
    "start": "node dist/index.js",
    "dev": "concurrently \"npm run build:css:watch\" \"ts-node-dev --respawn --transpile-only src/index.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "concurrently": "^9.2.1",
    "sass": "^1.98.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
